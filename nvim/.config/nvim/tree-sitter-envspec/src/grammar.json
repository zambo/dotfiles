{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "envspec",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "config_item"
          },
          {
            "type": "SYMBOL",
            "name": "divider"
          },
          {
            "type": "SYMBOL",
            "name": "comment_block"
          },
          {
            "type": "SYMBOL",
            "name": "blank_line"
          }
        ]
      }
    },
    "blank_line": {
      "type": "PATTERN",
      "value": "\\r?\\n"
    },
    "config_item": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "export_keyword"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "FIELD",
          "name": "key",
          "content": {
            "type": "SYMBOL",
            "name": "key"
          }
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "value",
              "content": {
                "type": "SYMBOL",
                "name": "_value"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "post_comment",
              "content": {
                "type": "SYMBOL",
                "name": "_comment_line"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "\\r?\\n"
        }
      ]
    },
    "export_keyword": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "export"
          },
          {
            "type": "PATTERN",
            "value": "[ \\t]+"
          }
        ]
      }
    },
    "key": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_.\\-]*"
    },
    "_comment_line": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "decorator_comment"
        },
        {
          "type": "SYMBOL",
          "name": "ignored_decorator_comment"
        },
        {
          "type": "SYMBOL",
          "name": "plain_comment"
        }
      ]
    },
    "decorator_comment": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "#"
            },
            {
              "type": "PATTERN",
              "value": "[ \\t]*"
            },
            {
              "type": "PATTERN",
              "value": "@[a-zA-Z][^\\r\\n]*"
            }
          ]
        }
      }
    },
    "ignored_decorator_comment": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "#"
            },
            {
              "type": "PATTERN",
              "value": "[ \\t]*"
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "PATTERN",
                      "value": "@[a-zA-Z][a-zA-Z0-9_]*:"
                    },
                    {
                      "type": "PATTERN",
                      "value": "[^\\r\\n]*"
                    }
                  ]
                },
                {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "PATTERN",
                      "value": "@[a-zA-Z][a-zA-Z0-9_]*"
                    },
                    {
                      "type": "PATTERN",
                      "value": "[ \\t]+[^@#\\r\\n][^\\r\\n]*"
                    }
                  ]
                }
              ]
            }
          ]
        }
      }
    },
    "plain_comment": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "#"
            },
            {
              "type": "PATTERN",
              "value": "[ \\t]*([^@\\r\\n][^\\r\\n]*|@[^a-zA-Z\\r\\n][^\\r\\n]*)?"
            }
          ]
        }
      }
    },
    "post_comment_text": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "#"
          },
          {
            "type": "PATTERN",
            "value": "[^\\r\\n]*"
          }
        ]
      }
    },
    "divider": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 3,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "#"
            },
            {
              "type": "PATTERN",
              "value": "[ \\t]*"
            },
            {
              "type": "PATTERN",
              "value": "[-=*#]{3,}"
            },
            {
              "type": "PATTERN",
              "value": "[^\\r\\n]*"
            }
          ]
        }
      }
    },
    "comment_block": {
      "type": "PREC_LEFT",
      "value": 0,
      "content": {
        "type": "REPEAT1",
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "FIELD",
              "name": "line",
              "content": {
                "type": "SYMBOL",
                "name": "_comment_line"
              }
            },
            {
              "type": "PATTERN",
              "value": "\\r?\\n"
            }
          ]
        }
      }
    },
    "_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "multiline_string"
        },
        {
          "type": "SYMBOL",
          "name": "quoted_string"
        },
        {
          "type": "SYMBOL",
          "name": "unquoted_string"
        }
      ]
    },
    "unquoted_string": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "[^'\"`#\\r\\n ][^#\\r\\n]*"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "expansion"
          }
        }
      ]
    },
    "unquoted_string_nospace": {
      "type": "PATTERN",
      "value": "[^'\"`# \\t\\r\\n]+"
    },
    "quoted_string": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "double_quoted_string"
        },
        {
          "type": "SYMBOL",
          "name": "single_quoted_string"
        },
        {
          "type": "SYMBOL",
          "name": "backtick_quoted_string"
        }
      ]
    },
    "double_quoted_string": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "\""
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "escape_sequence"
              },
              {
                "type": "SYMBOL",
                "name": "expansion"
              },
              {
                "type": "IMMEDIATE_TOKEN",
                "content": {
                  "type": "PATTERN",
                  "value": "[^\"\\\\$\\r\\n]+"
                }
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "\""
        }
      ]
    },
    "single_quoted_string": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "'"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "escape_sequence"
              },
              {
                "type": "IMMEDIATE_TOKEN",
                "content": {
                  "type": "PATTERN",
                  "value": "[^'\\\\\\r\\n]+"
                }
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "'"
        }
      ]
    },
    "backtick_quoted_string": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "`"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "escape_sequence"
              },
              {
                "type": "SYMBOL",
                "name": "expansion"
              },
              {
                "type": "IMMEDIATE_TOKEN",
                "content": {
                  "type": "PATTERN",
                  "value": "[^`\\\\$\\r\\n]+"
                }
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "`"
        }
      ]
    },
    "escape_sequence": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\\"
          },
          {
            "type": "PATTERN",
            "value": "[^\\r\\n]"
          }
        ]
      }
    },
    "multiline_string": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "triple_backtick_string"
        },
        {
          "type": "SYMBOL",
          "name": "triple_double_quoted_string"
        },
        {
          "type": "SYMBOL",
          "name": "multiline_double_quoted_string"
        },
        {
          "type": "SYMBOL",
          "name": "multiline_single_quoted_string"
        }
      ]
    },
    "triple_backtick_string": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "```"
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "PATTERN",
                    "value": "[^`]"
                  },
                  {
                    "type": "PATTERN",
                    "value": "`[^`]"
                  },
                  {
                    "type": "PATTERN",
                    "value": "``[^`]"
                  }
                ]
              }
            },
            {
              "type": "STRING",
              "value": "```"
            }
          ]
        }
      }
    },
    "triple_double_quoted_string": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "\"\"\""
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "PATTERN",
                    "value": "[^\"]"
                  },
                  {
                    "type": "PATTERN",
                    "value": "\\\"[^\"]"
                  },
                  {
                    "type": "PATTERN",
                    "value": "\\\"\\\"[^\"]"
                  }
                ]
              }
            },
            {
              "type": "STRING",
              "value": "\"\"\""
            }
          ]
        }
      }
    },
    "multiline_double_quoted_string": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\""
          },
          {
            "type": "PATTERN",
            "value": "[^\"\\r\\n]*"
          },
          {
            "type": "REPEAT1",
            "content": {
              "type": "SEQ",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "\\r?\\n"
                },
                {
                  "type": "PATTERN",
                  "value": "[^\"\\r\\n]*"
                }
              ]
            }
          },
          {
            "type": "STRING",
            "value": "\""
          }
        ]
      }
    },
    "multiline_single_quoted_string": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "'"
          },
          {
            "type": "PATTERN",
            "value": "[^'\\r\\n]*"
          },
          {
            "type": "REPEAT1",
            "content": {
              "type": "SEQ",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "\\r?\\n"
                },
                {
                  "type": "PATTERN",
                  "value": "[^'\\r\\n]*"
                }
              ]
            }
          },
          {
            "type": "STRING",
            "value": "'"
          }
        ]
      }
    },
    "expansion": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "${"
            },
            {
              "type": "FIELD",
              "name": "name",
              "content": {
                "type": "SYMBOL",
                "name": "identifier"
              }
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "STRING",
                      "value": ":-"
                    },
                    {
                      "type": "FIELD",
                      "name": "fallback",
                      "content": {
                        "type": "PATTERN",
                        "value": "[^}]+"
                      }
                    }
                  ]
                },
                {
                  "type": "BLANK"
                }
              ]
            },
            {
              "type": "STRING",
              "value": "}"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "$("
            },
            {
              "type": "FIELD",
              "name": "command",
              "content": {
                "type": "PATTERN",
                "value": "[^)]+"
              }
            },
            {
              "type": "STRING",
              "value": ")"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "IMMEDIATE_TOKEN",
              "content": {
                "type": "STRING",
                "value": "$"
              }
            },
            {
              "type": "FIELD",
              "name": "name",
              "content": {
                "type": "SYMBOL",
                "name": "identifier"
              }
            }
          ]
        }
      ]
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "function_call": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "function_name"
          }
        },
        {
          "type": "FIELD",
          "name": "args",
          "content": {
            "type": "SYMBOL",
            "name": "fn_args"
          }
        }
      ]
    },
    "function_name": {
      "type": "PATTERN",
      "value": "[a-zA-Z][a-zA-Z0-9_]*"
    },
    "fn_args": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "_fn_arg"
                },
                {
                  "type": "REPEAT",
                  "content": {
                    "type": "SEQ",
                    "members": [
                      {
                        "type": "STRING",
                        "value": ","
                      },
                      {
                        "type": "SYMBOL",
                        "name": "_fn_arg"
                      }
                    ]
                  }
                },
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "STRING",
                      "value": ","
                    },
                    {
                      "type": "BLANK"
                    }
                  ]
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "_fn_arg": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "key_value_pair"
        },
        {
          "type": "SYMBOL",
          "name": "function_call"
        },
        {
          "type": "SYMBOL",
          "name": "quoted_string"
        },
        {
          "type": "SYMBOL",
          "name": "unquoted_fn_arg"
        }
      ]
    },
    "key_value_pair": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "key",
          "content": {
            "type": "PATTERN",
            "value": "[a-zA-Z][a-zA-Z0-9_]*"
          }
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "quoted_string"
              },
              {
                "type": "SYMBOL",
                "name": "unquoted_fn_arg"
              },
              {
                "type": "SYMBOL",
                "name": "function_call"
              }
            ]
          }
        }
      ]
    },
    "unquoted_fn_arg": {
      "type": "PATTERN",
      "value": "[^ \\t\\r\\n,)]+"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t]"
    }
  ],
  "conflicts": [
    [
      "config_item"
    ]
  ],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}