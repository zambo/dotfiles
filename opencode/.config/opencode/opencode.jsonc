{
	"$schema": "https://opencode.ai/config.json",
	"default_agent": "plan",
	"disabled_providers": [
		"azure_openai",
		"cohere",
		"google_palm",
		"huggingface",
		"openai",
		"replicate",
		"stability_ai",
		"vertex_ai",
		"opencode"
	],
	"username": "zambo",
	"autoupdate": true,
	"plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
	"provider": {
		"fuel_ix": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "Fuel iX",
			"options": {
				"baseURL": "https://api.fuelix.ai/v1"
			},
			"models": {
				"claude-sonnet-4-5-20250929": {
					"name": "Claude Sonnet 4.5 (2025-09-29)",
					"reasoning": true
				},
				"claude-sonnet-4-6": {
					"name": "Claude Sonnet 4.6",
					"reasoning": true
				},
				"claude-haiku-4-5": {
					"name": "Claude Haiku 4.5"
				},
				"gemini-3.1-pro": {
					"name": "gemini-3.1-pro"
				},
				"gpt-5-2": {
					"name": "GPT 5.2 Chat"
				},
				"gpt-5.4-2026-03-05": {
					"name": "GPT 5.4"
				},
				"gpt-4-1": {
					"name": "GPT 4.1"
				}
			}
		}
	},
	"permission": {
		"read": {
			"~/.config/opencode/get-shit-done/*": "allow"
		},
		"external_directory": {
			"~/.config/opencode/get-shit-done/*": "allow"
		}
	}
}
