{
	"$schema": "https://opencode.ai/config.json",
	// Theme configuration
	"default_agent": "plan",
	"disabled_providers": [
		"azure_openai",
		"anthropic",
		"cohere",
		"google_palm",
		"huggingface",
		"openai",
		"replicate",
		"stability_ai",
		"vertex_ai",
		"opencode"
	],
	"username": "zambo",
	"autoupdate": true,
	// Permissions
	// "permission": {
	// 	"*": "ask",
	// 	"bash": {
	// 		"*": "ask",
	// 		"grep *": "allow",
	// 		"rga *": "allow",
	// 		"find *": "allow",
	// 		"fd *": "allow",
	// 		"ls *": "allow",
	// 		"cat *": "allow",
	// 		"bat *": "allow",
	// 		"head *": "allow",
	// 		"tail *": "allow"
	// 	},
	// 	"read": {
	// 		"*": "allow"
	// 	},
	// 	"write": {
	// 		"*": "deny"
	// 	},
	// 	"grep": {
	// 		"*": "allow"
	// 	}
	// },
	// Provider and Model configuration
	"provider": {
		"fuel_ix": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "Fuel iX",
			"options": {
				"baseURL": "https://api.fuelix.ai/v1"
			},
			"models": {
				"gpt-5.2-2025-12-11": {
					"name": "gpt-5.2-2025-12-11"
				},
				"claude-sonnet-4-5-20250929": {
					"name": "Claude Sonnet 4.5 (2025-09-29)",
					"reasoning": true
				},
				"claude-sonnet-4-5": {
					"name": "Claude Sonnet 4.5",
					"reasoning": true
				},
				"claude-sonnet-4-6": {
					"name": "Claude Sonnet 4.6",
					"reasoning": true
				},
				"claude-haiku-4-5": {
					"name": "Claude Haiku 4.5"
				},
				"gemini-3.1-pro": {
					"name": "gemini-3.1-pro"
				},
				"gpt-5-2": {
					"name": "GPT 5.2 Chat"
				},
				"gpt-5.4-2026-03-05": {
					"name": "GPT 5.4"
				},
				"gpt-4-1": {
					"name": "GPT 4.1"
				},
				"gpt-5": {
					"name": "GPT 5"
				},
				"gpt-5-chat": {
					"name": "GPT 5 Chat"
				},
				"gpt-5-mini": {
					"name": "GPT 5 Mini"
				}
			}
		}
	}
}
